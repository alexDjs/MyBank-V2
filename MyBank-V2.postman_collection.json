		{
			"name": "Account Management",
			"item": [
				{
					"name": "Get Account Info",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Account info retrieved successfully', function () {",
									"    pm.expect(pm.response.code).to.equal(200);",
									"    ",
									"    const responseJson = pm.response.json();",
									"    pm.expect(responseJson.account).to.exist;",
									"    pm.expect(responseJson.account.accountNumber).to.exist;",
									"    pm.expect(responseJson.account.balance).to.be.a('number');",
									"    pm.expect(responseJson.owner).to.exist;",
									"});",
									"",
									"// Save current balance for transaction tests",
									"if (pm.response.code === 200) {",
									"    const responseJson = pm.response.json();",
									"    pm.environment.set('current_balance', responseJson.account.balance);",
									"    console.log('Current balance:', responseJson.account.balance);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/account",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"account"
							]
						}
					},
					"response": []
				}
			]
