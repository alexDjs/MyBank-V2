		{
			"name": "Transactions",
			"item": [
				{
					"name": "Get All Transactions",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Transactions retrieved successfully', function () {",
									"    pm.expect(pm.response.code).to.equal(200);",
									"    ",
									"    const responseJson = pm.response.json();",
									"    pm.expect(responseJson.transactions).to.be.an('array');",
									"    ",
									"    if (responseJson.transactions.length > 0) {",
									"        const firstTransaction = responseJson.transactions[0];",
									"        pm.expect(firstTransaction.id).to.exist;",
									"        pm.expect(firstTransaction.type).to.exist;",
									"        pm.expect(firstTransaction.amount).to.be.a('number');",
									"        pm.expect(firstTransaction.direction).to.be.oneOf(['in', 'out']);",
									"    }",
									"});",
									"",
									"// Count transactions",
									"if (pm.response.code === 200) {",
									"    const responseJson = pm.response.json();",
									"    console.log('Total transactions:', responseJson.transactions.length);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/transactions",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"transactions"
							]
						}
					},
					"response": []
				},
				{
					"name": "Create Income Transaction",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Income transaction created successfully', function () {",
									"    pm.expect(pm.response.code).to.equal(201);",
									"    ",
									"    const responseJson = pm.response.json();",
									"    pm.expect(responseJson.message).to.equal('Transaction created successfully');",
									"    pm.expect(responseJson.transaction).to.exist;",
									"    pm.expect(responseJson.transaction.direction).to.equal('in');",
									"    pm.expect(responseJson.newBalance).to.be.a('number');",
									"});",
									"",
									"// Verify balance increased",
									"if (pm.response.code === 201) {",
									"    const responseJson = pm.response.json();",
									"    const currentBalance = pm.environment.get('current_balance');",
									"    const expectedBalance = parseFloat(currentBalance) + responseJson.transaction.amount;",
									"    ",
									"    pm.test('Balance increased correctly', function () {",
									"        pm.expect(responseJson.newBalance).to.be.closeTo(expectedBalance, 0.01);",
									"    });",
									"    ",
									"    // Update balance for next tests",
									"    pm.environment.set('current_balance', responseJson.newBalance);",
									"    console.log('New balance after income:', responseJson.newBalance);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization", 
								"value": "Bearer {{jwt_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"type\": \"Bonus\",\n  \"amount\": 500.00,\n  \"direction\": \"in\",\n  \"location\": \"Company Bonus Program\",\n  \"description\": \"Quarterly performance bonus\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/transactions",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"transactions"
							]
						}
					},
					"response": []
				},
				{
					"name": "Create Shopping Transaction",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Shopping transaction created successfully', function () {",
									"    pm.expect(pm.response.code).to.equal(201);",
									"    ",
									"    const responseJson = pm.response.json();",
									"    pm.expect(responseJson.message).to.equal('Transaction created successfully');",
									"    pm.expect(responseJson.transaction.direction).to.equal('out');",
									"    pm.expect(responseJson.newBalance).to.be.a('number');",
									"});",
									"",
									"// Verify balance decreased",
									"if (pm.response.code === 201) {",
									"    const responseJson = pm.response.json();",
									"    const currentBalance = pm.environment.get('current_balance');",
									"    const expectedBalance = parseFloat(currentBalance) - responseJson.transaction.amount;",
									"    ",
									"    pm.test('Balance decreased correctly', function () {",
									"        pm.expect(responseJson.newBalance).to.be.closeTo(expectedBalance, 0.01);",
									"    });",
									"    ",
									"    // Update balance for next tests",
									"    pm.environment.set('current_balance', responseJson.newBalance);",
									"    console.log('New balance after shopping:', responseJson.newBalance);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
