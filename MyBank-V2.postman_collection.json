				{
					"name": "Login (Demo User)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Extract JWT token from response",
									"if (pm.response.code === 200) {",
									"    const responseJson = pm.response.json();",
									"    const token = responseJson.token;",
									"    ",
									"    // Set token as environment variable",
									"    pm.environment.set('jwt_token', token);",
									"    ",
									"    // Set user info",
									"    pm.environment.set('user_email', responseJson.user.email);",
									"    pm.environment.set('user_name', responseJson.user.firstName + ' ' + responseJson.user.lastName);",
									"    ",
									"    console.log('JWT Token saved:', token);",
									"    ",
									"    // Test response",
									"    pm.test('Login successful', function () {",
									"        pm.expect(pm.response.code).to.equal(200);",
									"        pm.expect(responseJson.message).to.equal('Login successful');",
									"        pm.expect(responseJson.token).to.exist;",
									"    });",
									"} else {",
									"    pm.test('Login failed', function () {",
									"        pm.expect(pm.response.code).to.not.equal(200);",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
